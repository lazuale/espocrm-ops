# Рабочие env-файлы с реальными паролями и адресами.
.env
.env.dev
.env.prod
.env.smoke.*
.env.restore-drill.*
.env.local
.env.*.local
.support.*/

# Данные приложений и резервные копии.
storage/
backups/

# Архивы, дампы и временные артефакты.
*.sql
*.sql.gz
*.tar
*.tar.gz
*.zip
*.log
*.tmp
*.bak

# Приватные ключи, сертификаты и локальные секреты.
*.pem
*.key
*.crt
*.p12
*.pfx
secrets/

# Файлы операционной системы и IDE.
.DS_Store
Thumbs.db
.idea/
.vscode/

# Исключения: шаблоны env-файлов должны оставаться в репозитории.
!.env.dev.example
!.env.prod.example
