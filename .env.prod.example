# Продовый контур.
# Этот файл копируется в `.env.prod` и затем редактируется под конкретный сервер.

# Имя Compose-проекта для прода.
COMPOSE_PROJECT_NAME=espo-prod

# Зафиксированная версия образа EspoCRM.
ESPOCRM_IMAGE=espocrm/espocrm:9.3.4-apache

# Версия MariaDB.
MARIADB_TAG=10.11

# Каталог хранения данных БД прод-контура.
DB_STORAGE_DIR=./storage/prod/db

# Каталог хранения файлов и кода приложения прод-контура.
ESPO_STORAGE_DIR=./storage/prod/espo

# Каталог продовых бэкапов.
BACKUP_ROOT=./backups/prod

# Префикс имен backup-файлов.
BACKUP_NAME_PREFIX=espocrm-prod

# Срок хранения продовых бэкапов в днях.
BACKUP_RETENTION_DAYS=7

# Максимально допустимый возраст последнего backup БД для аудита.
BACKUP_MAX_DB_AGE_HOURS=36

# Максимально допустимый возраст последнего backup файлов для аудита.
BACKUP_MAX_FILES_AGE_HOURS=36

# Срок хранения служебных отчетов update/status в днях.
REPORT_RETENTION_DAYS=30

# Срок хранения support bundle в днях.
SUPPORT_RETENTION_DAYS=14

# Рекомендуемый минимальный свободный объем на файловой системе (в MB).
MIN_FREE_DISK_MB=4096

# Ротация stdout/stderr-логов контейнеров Docker.
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5

# Ограничения ресурсов для MariaDB.
DB_MEM_LIMIT=1g
DB_CPUS=1.50
DB_PIDS_LIMIT=256

# Ограничения ресурсов для основного веб-контейнера EspoCRM.
ESPO_MEM_LIMIT=1g
ESPO_CPUS=1.00
ESPO_PIDS_LIMIT=256

# Ограничения ресурсов для фонового daemon-контейнера.
DAEMON_MEM_LIMIT=512m
DAEMON_CPUS=0.50
DAEMON_PIDS_LIMIT=128

# Ограничения ресурсов для websocket-контейнера.
WS_MEM_LIMIT=256m
WS_CPUS=0.50
WS_PIDS_LIMIT=128

# Порт внешнего HTTP-доступа к прод-контурy.
APP_PORT=8080

# Порт внешнего websocket-доступа к прод-контурy.
WS_PORT=8081

# Публичный URL продового контура.
SITE_URL=http://YOUR_SERVER_IP:8080

# Публичный websocket-URL продового контура.
WS_PUBLIC_URL=ws://YOUR_SERVER_IP:8081

# Пароль root в MariaDB для прода.
DB_ROOT_PASSWORD=change_me_prod_root

# Имя БД прод-контура.
DB_NAME=espocrm

# Пользователь БД прод-контура.
DB_USER=espocrm

# Пароль пользователя БД прод-контура.
DB_PASSWORD=change_me_prod_db

# Логин администратора EspoCRM в проде.
ADMIN_USERNAME=admin

# Пароль администратора EspoCRM в проде.
ADMIN_PASSWORD=change_me_prod_admin

# Язык интерфейса по умолчанию.
ESPO_DEFAULT_LANGUAGE=ru_RU

# Часовой пояс по умолчанию.
ESPO_TIME_ZONE=Europe/Moscow

# Продовый уровень логирования.
ESPO_LOGGER_LEVEL=WARNING
