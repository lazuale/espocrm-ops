    ],
    "json": [
      "espops --json"
    ]
  },
  "changed_file_rules": [
    {
      "requires_any_prefix": [
        "AI/compiled/"
      ],
      "trigger_prefixes": [
        "AGENTS.md",
        "AI/spec/",
        "AI/generators/",
        "Makefile",
        ".github/workflows/ai-governance.yml"
      ]
    },
    {
      "requires_any_prefix": [
        "AI/compiled/CONTRACT_BASELINE.json",
        "AI/compiled/JSON_CONTRACT_BASELINE/"
      ],
      "trigger_prefixes": [
        "internal/contract/",
        "internal/cli/"
      ]
    },
    {
      "requires_any_prefix": [
        "AI/compiled/"
      ],
      "trigger_prefixes": [
        "scripts/doctor.sh",
        "scripts/backup.sh",
        "scripts/restore.sh",
        "scripts/migrate.sh",
        "scripts/espo.sh",
        "scripts/regression-test.sh",
        "scripts/lib/common.sh"
      ]
    }
  ],
  "contributing_forbidden_snippets": [
    "## Required Documents Before Architectural Changes",
    "If the PR changes an architectural boundary, see the detailed regulation",
    "Archived human docs"
  ],
  "contributing_required_snippets": [
    "[AGENTS.md](AGENTS.md)",
    "`AI/spec/*`",
    "This file is onboarding only. Repository authority lives in `AGENTS.md` and `AI/spec/*`.",
    "`make ai-refresh`",
    "`make ai-check`",
    "`make ci`"
  ],
  "frozen_shell_debt": {},
  "json_fixture_glob": "internal/cli/testdata/*.json",
