    "scripts/doctor.sh"
  ],
  "passthrough_shell_json": [
    "scripts/doctor.sh --json"
  ],
  "readme_required_snippets": [
    "[AGENTS.md](AGENTS.md)",
    "`AI/spec/*`",
    "`make ai-refresh`",
    "`make ai-check`",
    "`make ci`",
    "Do not edit `AI/compiled/*` manually. Regenerate it with `make ai-refresh`."
