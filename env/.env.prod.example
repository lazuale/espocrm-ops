# Copy to `.env.prod`.

ESPO_CONTOUR=prod
COMPOSE_PROJECT_NAME=espo-prod

# Keep image, DB, language, and time zone aligned with dev for predictable migrate and restore behavior.
ESPOCRM_IMAGE=espocrm/espocrm:9.3.4-apache
MARIADB_TAG=11.4
# Set the EspoCRM runtime ownership explicitly; espops will not autodetect it from the image.
ESPO_RUNTIME_UID=33
ESPO_RUNTIME_GID=33
DB_STORAGE_DIR=../espocrm-data/runtime/prod/db
ESPO_STORAGE_DIR=../espocrm-data/runtime/prod/espo
BACKUP_ROOT=../espocrm-data/backups/prod
# Backup names use BACKUP_NAME_PREFIX directly, MIN_FREE_DISK_MB gates backup before service stop, and BACKUP_RETENTION_DAYS=0 disables cleanup.
BACKUP_NAME_PREFIX=espocrm-prod
BACKUP_RETENTION_DAYS=7
APP_SERVICES=espocrm,espocrm-daemon,espocrm-websocket
DB_SERVICE=db
MIN_FREE_DISK_MB=4096
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5
DB_MEM_LIMIT=1g
DB_CPUS=1.50
DB_PIDS_LIMIT=256
ESPO_MEM_LIMIT=1g
ESPO_CPUS=1.00
ESPO_PIDS_LIMIT=256
DAEMON_MEM_LIMIT=512m
DAEMON_CPUS=0.50
DAEMON_PIDS_LIMIT=128
WS_MEM_LIMIT=256m
WS_CPUS=0.50
WS_PIDS_LIMIT=128
APP_BIND_ADDRESS=127.0.0.1
APP_PORT=8080
WS_BIND_ADDRESS=127.0.0.1
WS_PORT=8081
SITE_URL=http://127.0.0.1:8080
WS_PUBLIC_URL=ws://127.0.0.1:8081
DB_ROOT_PASSWORD=change_me_prod_root
DB_NAME=espocrm
DB_USER=espocrm
DB_PASSWORD=change_me_prod_db
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_prod_admin
ESPO_DEFAULT_LANGUAGE=ru_RU
ESPO_TIME_ZONE=Europe/Moscow
ESPO_LOGGER_LEVEL=WARNING
