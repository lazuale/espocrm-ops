# Copy to `.env.dev`.

ESPO_CONTOUR=dev
COMPOSE_PROJECT_NAME=espo-dev

# Keep image, DB, language, and time zone aligned with prod for migrate and restore compatibility.
ESPOCRM_IMAGE=espocrm/espocrm:9.3.4-apache
MARIADB_TAG=10.11
# Provide one explicit helper image and pre-pull it yourself. Pin by digest in real deployments.
ESPO_HELPER_IMAGE=alpine:3.20
# Set the EspoCRM runtime ownership explicitly; espops will not autodetect it from the image.
ESPO_RUNTIME_UID=33
ESPO_RUNTIME_GID=33
DB_STORAGE_DIR=../espocrm-data/runtime/dev/db
ESPO_STORAGE_DIR=../espocrm-data/runtime/dev/espo
BACKUP_ROOT=../espocrm-data/backups/dev
BACKUP_NAME_PREFIX=espocrm-dev
BACKUP_RETENTION_DAYS=7
MIN_FREE_DISK_MB=2048
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5
DB_MEM_LIMIT=768m
DB_CPUS=1.00
DB_PIDS_LIMIT=256
ESPO_MEM_LIMIT=768m
ESPO_CPUS=0.75
ESPO_PIDS_LIMIT=256
DAEMON_MEM_LIMIT=384m
DAEMON_CPUS=0.50
DAEMON_PIDS_LIMIT=128
WS_MEM_LIMIT=256m
WS_CPUS=0.50
WS_PIDS_LIMIT=128
APP_PORT=8088
WS_PORT=8089
SITE_URL=http://127.0.0.1:8088
WS_PUBLIC_URL=ws://127.0.0.1:8089
DB_ROOT_PASSWORD=change_me_dev_root
DB_NAME=espocrm_dev
DB_USER=espocrm
DB_PASSWORD=change_me_dev_db
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_dev_admin
ESPO_DEFAULT_LANGUAGE=ru_RU
ESPO_TIME_ZONE=Europe/Moscow
ESPO_LOGGER_LEVEL=INFO
