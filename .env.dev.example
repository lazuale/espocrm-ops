# Дев-контур.
# Этот файл копируется в `.env.dev` и затем редактируется под локальную/тестовую среду.

# Имя Compose-проекта для dev.
COMPOSE_PROJECT_NAME=espo-dev

# Версия образа EspoCRM для dev.
ESPOCRM_IMAGE=espocrm/espocrm:9.3.4-apache

# Версия MariaDB для dev.
MARIADB_TAG=10.11

# Каталог хранения данных БД дев-контура.
DB_STORAGE_DIR=./storage/dev/db

# Каталог хранения файлов и кода приложения дев-контура.
ESPO_STORAGE_DIR=./storage/dev/espo

# Каталог девовых бэкапов.
BACKUP_ROOT=./backups/dev

# Префикс имен backup-файлов.
BACKUP_NAME_PREFIX=espocrm-dev

# Срок хранения девовых бэкапов в днях.
BACKUP_RETENTION_DAYS=7

# Максимально допустимый возраст последнего backup БД для аудита.
BACKUP_MAX_DB_AGE_HOURS=72

# Максимально допустимый возраст последнего backup файлов для аудита.
BACKUP_MAX_FILES_AGE_HOURS=72

# Срок хранения служебных отчетов update/status в днях.
REPORT_RETENTION_DAYS=30

# Срок хранения support bundle в днях.
SUPPORT_RETENTION_DAYS=14

# Рекомендуемый минимальный свободный объем на файловой системе (в MB).
MIN_FREE_DISK_MB=2048

# Ротация stdout/stderr-логов контейнеров Docker.
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5

# Ограничения ресурсов для MariaDB.
DB_MEM_LIMIT=768m
DB_CPUS=1.00
DB_PIDS_LIMIT=256

# Ограничения ресурсов для основного веб-контейнера EspoCRM.
ESPO_MEM_LIMIT=768m
ESPO_CPUS=0.75
ESPO_PIDS_LIMIT=256

# Ограничения ресурсов для фонового daemon-контейнера.
DAEMON_MEM_LIMIT=384m
DAEMON_CPUS=0.50
DAEMON_PIDS_LIMIT=128

# Ограничения ресурсов для websocket-контейнера.
WS_MEM_LIMIT=256m
WS_CPUS=0.50
WS_PIDS_LIMIT=128

# Порт HTTP для dev.
APP_PORT=8088

# Порт websocket для dev.
WS_PORT=8089

# Публичный URL dev-контура.
SITE_URL=http://127.0.0.1:8088

# Публичный websocket-URL dev-контура.
WS_PUBLIC_URL=ws://127.0.0.1:8089

# Пароль root в MariaDB для dev.
DB_ROOT_PASSWORD=change_me_dev_root

# Имя БД dev-контура.
DB_NAME=espocrm_dev

# Пользователь БД dev-контура.
DB_USER=espocrm

# Пароль пользователя БД dev-контура.
DB_PASSWORD=change_me_dev_db

# Логин администратора EspoCRM в dev.
ADMIN_USERNAME=admin

# Пароль администратора EspoCRM в dev.
ADMIN_PASSWORD=change_me_dev_admin

# Язык интерфейса по умолчанию.
ESPO_DEFAULT_LANGUAGE=ru_RU

# Часовой пояс по умолчанию.
ESPO_TIME_ZONE=Europe/Moscow

# Для dev логирование можно держать чуть подробнее.
ESPO_LOGGER_LEVEL=INFO
